{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourcing-ai-agent.local/contracts/frontend_api_contract.schema.json",
  "title": "Sourcing AI Agent Frontend API Contract Bundle",
  "description": "Use $defs/PlanResponse, $defs/ReviewInstructionCompileResponse, $defs/WorkflowStartResponse, $defs/QueryDispatchListResponse, $defs/JobProgressResponse, $defs/JobResultsResponse, $defs/RetrievalJobResponse, $defs/TargetCandidatePublicWebSearchState, $defs/TargetCandidatePublicWebStartResponse, $defs/TargetCandidatePublicWebDetailResponse, $defs/TargetCandidatePublicWebPromotionResponse, or $defs/RefinementCompileResponse.",
  "type": "object",
  "$defs": {
    "JsonObject": {
      "type": "object",
      "additionalProperties": true
    },
    "StringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "IntentRewriteRule": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "rewrite_id": { "type": "string" },
        "summary_label": { "type": "string" },
        "policy_layer": { "type": "string" },
        "keywords": { "$ref": "#/$defs/StringArray" },
        "must_have_facets": { "$ref": "#/$defs/StringArray" },
        "must_have_primary_role_buckets": { "$ref": "#/$defs/StringArray" },
        "must_have_keywords": { "$ref": "#/$defs/StringArray" },
        "targeting_terms": { "$ref": "#/$defs/StringArray" },
        "matched_terms": { "$ref": "#/$defs/StringArray" },
        "request_patch": { "$ref": "#/$defs/JsonObject" },
        "trigger_sources": { "$ref": "#/$defs/JsonObject" },
        "additional_rewrites": {
          "type": "array",
          "items": { "$ref": "#/$defs/IntentRewriteRule" }
        },
        "notes": { "type": "string" }
      }
    },
    "IntentRewritePolicyCatalogEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "rewrite_id": { "type": "string" },
        "summary_label": { "type": "string" },
        "policy_layer": { "type": "string" },
        "trigger_sources": { "$ref": "#/$defs/JsonObject" },
        "request_patch": { "$ref": "#/$defs/JsonObject" },
        "targeting_terms": { "$ref": "#/$defs/StringArray" },
        "notes": { "type": "string" }
      }
    },
    "IntentRewriteEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matched", "summary", "rewrite"],
      "properties": {
        "matched": { "type": "boolean" },
        "summary": { "type": "string" },
        "rewrite": {
          "oneOf": [
            { "$ref": "#/$defs/IntentRewriteRule" },
            {
              "type": "object",
              "maxProperties": 0
            }
          ]
        }
      }
    },
    "IntentRewritePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request"],
      "properties": {
        "request": { "$ref": "#/$defs/IntentRewriteEntry" },
        "instruction": { "$ref": "#/$defs/IntentRewriteEntry" },
        "policy_catalog": {
          "type": "array",
          "items": { "$ref": "#/$defs/IntentRewritePolicyCatalogEntry" }
        }
      }
    },
    "IntentBrief": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "identified_request",
        "target_output",
        "default_execution_strategy",
        "review_focus"
      ],
      "properties": {
        "identified_request": { "$ref": "#/$defs/StringArray" },
        "target_output": { "$ref": "#/$defs/StringArray" },
        "default_execution_strategy": { "$ref": "#/$defs/StringArray" },
        "review_focus": { "$ref": "#/$defs/StringArray" }
      }
    },
    "PlanReviewGate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string" },
        "required_before_execution": { "type": "boolean" },
        "risk_level": { "type": "string" },
        "reasons": { "$ref": "#/$defs/StringArray" },
        "confirmation_items": { "$ref": "#/$defs/StringArray" },
        "editable_fields": { "$ref": "#/$defs/StringArray" },
        "suggested_actions": { "$ref": "#/$defs/StringArray" },
        "execution_mode_hints": { "$ref": "#/$defs/JsonObject" }
      }
    },
    "SourcingPlanSummary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "target_company": { "type": "string" },
        "intent_summary": { "type": "string" },
        "criteria_summary": { "type": "string" },
        "intent_brief": { "$ref": "#/$defs/IntentBrief" },
        "retrieval_plan": { "$ref": "#/$defs/JsonObject" },
        "acquisition_strategy": { "$ref": "#/$defs/JsonObject" },
        "acquisition_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "search_strategy": { "$ref": "#/$defs/JsonObject" },
        "open_questions": { "$ref": "#/$defs/StringArray" },
        "assumptions": { "$ref": "#/$defs/StringArray" }
      }
    },
    "InstructionCompiler": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string" },
        "provider": { "type": "string" },
        "allowed_fields": { "$ref": "#/$defs/StringArray" },
        "supplemented_keys": { "$ref": "#/$defs/StringArray" },
        "policy_inferred_keys": { "$ref": "#/$defs/StringArray" },
        "fallback_used": { "type": "boolean" },
        "model_decision": { "$ref": "#/$defs/JsonObject" },
        "deterministic_decision": { "$ref": "#/$defs/JsonObject" },
        "model_patch": { "$ref": "#/$defs/JsonObject" },
        "deterministic_patch": { "$ref": "#/$defs/JsonObject" },
        "request_intent_rewrite": {
          "oneOf": [
            { "$ref": "#/$defs/IntentRewriteRule" },
            { "$ref": "#/$defs/JsonObject" }
          ]
        },
        "instruction_intent_rewrite": {
          "oneOf": [
            { "$ref": "#/$defs/IntentRewriteRule" },
            { "$ref": "#/$defs/JsonObject" }
          ]
        }
      }
    },
    "PlanResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "request",
        "plan",
        "plan_review_gate",
        "plan_review_session",
        "intent_rewrite"
      ],
      "properties": {
        "request": { "$ref": "#/$defs/JsonObject" },
        "request_preview": { "$ref": "#/$defs/JsonObject" },
        "plan": { "$ref": "#/$defs/SourcingPlanSummary" },
        "plan_review_gate": { "$ref": "#/$defs/PlanReviewGate" },
        "plan_review_session": { "$ref": "#/$defs/JsonObject" },
        "intent_rewrite": { "$ref": "#/$defs/IntentRewritePayload" },
        "criteria_version_id": { "type": "integer" },
        "criteria_compiler_run_id": { "type": "integer" },
        "criteria_request_signature": { "type": "string" }
      }
    },
    "ReviewInstructionCompileResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["compiled", "invalid", "not_found"]
        },
        "review_id": { "type": "integer" },
        "reason": { "type": "string" },
        "review_payload": { "$ref": "#/$defs/JsonObject" },
        "instruction_compiler": { "$ref": "#/$defs/InstructionCompiler" },
        "intent_rewrite": { "$ref": "#/$defs/IntentRewritePayload" }
      }
    },
    "ReviewPlanApplyResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": { "type": "string" },
        "review": { "$ref": "#/$defs/JsonObject" },
        "instruction_compiler": { "$ref": "#/$defs/InstructionCompiler" },
        "intent_rewrite": { "$ref": "#/$defs/IntentRewritePayload" }
      }
    },
    "WorkflowStartResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "job_id": { "type": "string" },
        "status": { "type": "string" },
        "stage": { "type": "string" },
        "plan": { "$ref": "#/$defs/SourcingPlanSummary" },
        "plan_review_session": { "$ref": "#/$defs/JsonObject" },
        "plan_review_gate": { "$ref": "#/$defs/PlanReviewGate" },
        "reason": { "type": "string" },
        "intent_rewrite": { "$ref": "#/$defs/IntentRewritePayload" },
        "dispatch": { "$ref": "#/$defs/QueryDispatchRecord" },
        "criteria_version_id": { "type": "integer" },
        "criteria_compiler_run_id": { "type": "integer" },
        "criteria_request_signature": { "type": "string" }
      }
    },
    "QueryDispatchRecord": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dispatch_id": { "type": "integer" },
        "target_company": { "type": "string" },
        "request_signature": { "type": "string" },
        "request_family_signature": { "type": "string" },
        "requester_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "idempotency_key": { "type": "string" },
        "strategy": { "type": "string" },
        "status": { "type": "string" },
        "source_job_id": { "type": "string" },
        "created_job_id": { "type": "string" },
        "payload": { "$ref": "#/$defs/JsonObject" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "QueryDispatchListResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["query_dispatches"],
      "properties": {
        "query_dispatches": {
          "type": "array",
          "items": { "$ref": "#/$defs/QueryDispatchRecord" }
        }
      }
    },
    "JobMilestone": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stage", "status"],
      "properties": {
        "stage": { "type": "string" },
        "status": { "type": "string" },
        "started_at": { "type": "string" },
        "completed_at": { "type": "string" },
        "latest_detail": { "type": "string" },
        "event_count": { "type": "integer" },
        "elapsed_seconds": { "type": "integer" }
      }
    },
    "WorkerLaneSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["lane_id", "worker_count", "by_status", "raw_by_status"],
      "properties": {
        "lane_id": { "type": "string" },
        "worker_count": { "type": "integer" },
        "by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "raw_by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "last_updated_at": { "type": "string" }
      }
    },
    "WorkerSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["by_status", "raw_by_status", "by_lane"],
      "properties": {
        "by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "raw_by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "by_lane": {
          "type": "array",
          "items": { "$ref": "#/$defs/WorkerLaneSummary" }
        }
      }
    },
    "ProgressPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "stage_order",
        "current_stage",
        "completed_stages",
        "milestones",
        "timing",
        "worker_summary",
        "counters"
      ],
      "properties": {
        "stage_order": { "$ref": "#/$defs/StringArray" },
        "current_stage": { "type": "string" },
        "completed_stages": { "$ref": "#/$defs/StringArray" },
        "milestones": {
          "type": "array",
          "items": { "$ref": "#/$defs/JobMilestone" }
        },
        "timing": { "$ref": "#/$defs/JsonObject" },
        "latest_event": { "$ref": "#/$defs/JsonObject" },
        "worker_summary": { "$ref": "#/$defs/WorkerSummary" },
        "latest_metrics": { "$ref": "#/$defs/JsonObject" },
        "counters": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    },
    "WorkflowStageSummaryItem": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "stage": { "type": "string" },
        "status": { "type": "string" },
        "summary_path": { "type": "string" }
      }
    },
    "WorkflowStageSummariesPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stage_order", "summaries"],
      "properties": {
        "directory": { "type": "string" },
        "stage_order": { "$ref": "#/$defs/StringArray" },
        "summaries": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/WorkflowStageSummaryItem" }
        }
      }
    },
    "JobProgressResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["job_id", "status", "stage", "progress"],
      "properties": {
        "job_id": { "type": "string" },
        "status": { "type": "string" },
        "stage": { "type": "string" },
        "started_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "elapsed_seconds": { "type": "integer" },
        "blocked_task": { "type": "string" },
        "current_message": { "type": "string" },
        "progress": { "$ref": "#/$defs/ProgressPayload" },
        "workflow_stage_summaries": { "$ref": "#/$defs/WorkflowStageSummariesPayload" }
      }
    },
    "MatchResult": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "candidate_id": { "type": "string" },
        "display_name": { "type": "string" },
        "name_en": { "type": "string" },
        "name_zh": { "type": "string" },
        "category": { "type": "string" },
        "target_company": { "type": "string" },
        "organization": { "type": "string" },
        "employment_status": { "type": "string" },
        "role_bucket": { "type": "string" },
        "functional_facets": { "$ref": "#/$defs/StringArray" },
        "role": { "type": "string" },
        "team": { "type": "string" },
        "focus_areas": { "type": "string" },
        "education": { "type": "string" },
        "work_history": { "type": "string" },
        "notes": { "type": "string" },
        "linkedin_url": { "type": "string" },
        "score": { "type": "number" },
        "semantic_score": { "type": "number" },
        "confidence_label": { "type": "string" },
        "confidence_score": { "type": "number" },
        "confidence_reason": { "type": "string" },
        "rank": { "type": "integer" },
        "matched_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "explanation": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        }
      }
    },
    "JobResultsResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "job",
        "events",
        "results",
        "manual_review_items",
        "agent_runtime_session",
        "agent_trace_spans",
        "agent_workers",
        "intent_rewrite"
      ],
      "properties": {
        "job": { "$ref": "#/$defs/JsonObject" },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "manual_review_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "agent_runtime_session": { "$ref": "#/$defs/JsonObject" },
        "agent_trace_spans": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "agent_workers": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "intent_rewrite": { "$ref": "#/$defs/IntentRewritePayload" },
        "request_preview": { "$ref": "#/$defs/JsonObject" },
        "workflow_stage_summaries": { "$ref": "#/$defs/WorkflowStageSummariesPayload" }
      }
    },
    "RetrievalJobResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "job_id",
        "status",
        "request",
        "plan",
        "intent_rewrite",
        "summary",
        "matches",
        "manual_review_items"
      ],
      "properties": {
        "job_id": { "type": "string" },
        "status": { "type": "string" },
        "request": { "$ref": "#/$defs/JsonObject" },
        "request_preview": { "$ref": "#/$defs/JsonObject" },
        "plan": {
          "oneOf": [
            { "$ref": "#/$defs/SourcingPlanSummary" },
            { "$ref": "#/$defs/JsonObject" }
          ]
        },
        "intent_rewrite": { "$ref": "#/$defs/IntentRewritePayload" },
        "summary": { "$ref": "#/$defs/JsonObject" },
        "matches": {
          "type": "array",
          "items": { "$ref": "#/$defs/MatchResult" }
        },
        "manual_review_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "criteria_patterns_applied": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "semantic_hits": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "confidence_policy": { "$ref": "#/$defs/JsonObject" },
        "confidence_policy_control": { "$ref": "#/$defs/JsonObject" },
        "runtime_policy": { "$ref": "#/$defs/JsonObject" },
        "artifact_path": { "type": "string" }
      }
    },
    "TargetCandidatePublicWebStatus": {
      "type": "string",
      "enum": [
        "queued",
        "search_submitted",
        "searching",
        "entry_links_ready",
        "fetching",
        "analyzing",
        "completed",
        "completed_with_errors",
        "needs_review",
        "failed",
        "cancelled",
        "unknown"
      ]
    },
    "TargetCandidatePublicWebBatch": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "requested_record_ids",
        "run_ids",
        "source_families",
        "summary"
      ],
      "properties": {
        "batch_id": { "type": "string" },
        "status": { "$ref": "#/$defs/TargetCandidatePublicWebStatus" },
        "requested_record_ids": { "$ref": "#/$defs/StringArray" },
        "run_ids": { "$ref": "#/$defs/StringArray" },
        "source_families": { "$ref": "#/$defs/StringArray" },
        "summary": { "$ref": "#/$defs/JsonObject" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "TargetCandidatePublicWebRun": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "source_families",
        "summary",
        "query_manifest",
        "search_checkpoint",
        "analysis_checkpoint"
      ],
      "properties": {
        "run_id": { "type": "string" },
        "batch_id": { "type": "string" },
        "record_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "candidate_name": { "type": "string" },
        "current_company": { "type": "string" },
        "linkedin_url": { "type": "string" },
        "status": { "$ref": "#/$defs/TargetCandidatePublicWebStatus" },
        "phase": { "type": "string" },
        "source_families": { "$ref": "#/$defs/StringArray" },
        "summary": { "$ref": "#/$defs/JsonObject" },
        "query_manifest": {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonObject" }
        },
        "search_checkpoint": { "$ref": "#/$defs/JsonObject" },
        "analysis_checkpoint": { "$ref": "#/$defs/JsonObject" },
        "artifact_root": { "type": "string" },
        "last_error": { "type": "string" },
        "started_at": { "type": "string" },
        "completed_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "TargetCandidatePublicWebSearchState": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "batches", "runs"],
      "properties": {
        "status": { "type": "string" },
        "batches": {
          "type": "array",
          "items": { "$ref": "#/$defs/TargetCandidatePublicWebBatch" }
        },
        "runs": {
          "type": "array",
          "items": { "$ref": "#/$defs/TargetCandidatePublicWebRun" }
        }
      }
    },
    "TargetCandidatePublicWebStartResponse": {
      "allOf": [
        { "$ref": "#/$defs/TargetCandidatePublicWebSearchState" },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["summary", "worker_summary", "job"],
          "properties": {
            "batch": {
              "oneOf": [
                { "$ref": "#/$defs/TargetCandidatePublicWebBatch" },
                { "type": "null" }
              ]
            },
            "summary": { "$ref": "#/$defs/JsonObject" },
            "worker_summary": { "$ref": "#/$defs/JsonObject" },
            "job": { "$ref": "#/$defs/JsonObject" }
          }
        }
      ]
    },
    "TargetCandidatePublicWebSignal": {
      "type": "object",
      "additionalProperties": true,
      "required": ["signal_kind"],
      "properties": {
        "signal_id": { "type": "string" },
        "run_id": { "type": "string" },
        "asset_id": { "type": "string" },
        "person_identity_key": { "type": "string" },
        "record_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "signal_kind": { "type": "string" },
        "signal_type": { "type": "string" },
        "email_type": { "type": "string" },
        "value": { "type": "string" },
        "normalized_value": { "type": "string" },
        "url": { "type": "string" },
        "source_url": { "type": "string" },
        "source_domain": { "type": "string" },
        "source_family": { "type": "string" },
        "source_title": { "type": "string" },
        "confidence_label": { "type": "string" },
        "confidence_score": { "type": "number" },
        "identity_match_label": { "type": "string" },
        "identity_match_score": { "type": "number" },
        "publishable": { "type": "boolean" },
        "promotion_status": { "type": "string" },
        "promotion_id": { "type": "string" },
        "promotion_action": { "type": "string" },
        "promoted_field": { "type": "string" },
        "promoted_value": { "type": "string" },
        "previous_value": { "type": "string" },
        "promoted_by": { "type": "string" },
        "promoted_at": { "type": "string" },
        "promotion_note": { "type": "string" },
        "suppression_reason": { "type": "string" },
        "evidence_excerpt": { "type": "string" },
        "artifact_refs": { "$ref": "#/$defs/JsonObject" },
        "model_provider": { "type": "string" },
        "model_version": { "type": "string" },
        "link_shape_warnings": { "$ref": "#/$defs/StringArray" },
        "clean_profile_link": { "type": "boolean" },
        "metadata": { "$ref": "#/$defs/JsonObject" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "TargetCandidatePublicWebPromotion": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "promotion_id": { "type": "string" },
        "signal_id": { "type": "string" },
        "run_id": { "type": "string" },
