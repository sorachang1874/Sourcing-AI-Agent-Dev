    "publications": [
      {
        "title": "Kernel similarity matching with Hebbian networks",
        "publishedAt": "Neurips",
        "description": "We derive a network with online Hebbian learning rules capable of performing kernel similarity matching.",
        "link": "https://openreview.net/forum?id=NSophzmqq8Y"
      },
      {
        "title": "Learning and segmenting dense voxel embeddings for 3D neuron reconstruction",
        "publishedAt": "IEEE Transactions on Medical Imaging",
        "description": "We use convolutional networks to assign an embedding vector to every voxel (3D pixel). These embedding vectors which are then used to segment 3D volumetric microscopy images.",
        "link": "https://ieeexplore.ieee.org/document/9489304"
      },
      {
        "title": "Learning metric graphs for neuron segmentation in electron microscopy images",
        "publishedAt": "IEEE International Symposium on Biomedical Imaging",
        "description": "We use convolutional networks to assign an embedding vector to every pixel in 2D micrscopy images of brain tissue. These embedding vectors are then used to segment every neuron.",
        "link": "https://ieeexplore.ieee.org/document/8759576"
      },
      {
        "title": "Reexamining the principle of mean-variance preservation for neural network initialization",
        "publishedAt": "Physical Review Research",
        "description": "We prove that in a wide ReLU network the variance of individual neurons decays to zero with depth, even when networks are initialized with the popular Kaiming initialization.",
        "link": "https://journals.aps.org/prresearch/abstract/10.1103/PhysRevResearch.2.033135"
      },
      {
        "title": "Sensitivity of sparse codes to image distortions",
        "publishedAt": "Neural Computation",
        "description": "We identify and explain the following: a linear classifier trained to classify MNIST digits has lower test set performance when classifying the outputs of a sparse coding module than when classifying the raw pixels.",
        "link": "https://direct.mit.edu/neco/article/34/7/1616/111334/Sensitivity-of-Sparse-Codes-to-Image-Distortions"
      },
      {
        "title": "Stacked unsupervised learning with a network architecture found by supervised meta-learning",
        "publishedAt": "Arxiv",
        "description": "We train a deep neural network to classify objects without using backpropagation. We devise layer-local learning rules and use evolutionary algorithms to tune the parameters of the learning rules so that the network achieves high recognition performance.",
        "link": "https://arxiv.org/abs/2206.02716"
      },
      {
        "title": "Unsupervised learning by a softened correlation game: duality and convergence",
        "publishedAt": "Asilomar Conference on Signals, Systems & Computers",
        "description": "We analyze convergence and duality guarantees in a recently proposed model of cortical learning which pits excitatory and inhibitory neurons against each other in a two player zero-sum game.",
        "link": "https://ieeexplore.ieee.org/abstract/document/9048957"
      }
    ],
